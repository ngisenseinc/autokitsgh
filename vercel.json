{
  "version": 2,
  "builds": [
    {
      "src": "autokitsgh/api/gemini-chat.js",
      "use": "@vercel/node"
    },
    {
      "src": "autokitsgh/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/gemini-chat(.*)",
      "dest": "/autokitsgh/api/gemini-chat.js"
    },
    {
      "src": "/(.*)",
      "dest": "/autokitsgh/dist/$1"
    }
  ]
}
